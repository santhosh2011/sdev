# Per-task standalone compose, generated by bin/new-task.
# Generic example stack: db + redis + api + ui + nginx. This is the DEFAULT
# template. Give a project its own template (see core/projects.d/example.yml)
# to model a different stack. Host ports come from .env (<SVC>_HOST_PORT).
services:
  db:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app
      POSTGRES_DB: app
    ports:
      - "127.0.0.1:${DB_HOST_PORT}:5432"
    volumes:
      - db-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "app"]
      interval: 5s
      timeout: 5s
      retries: 20
    networks: [task-net]

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    ports:
      - "127.0.0.1:${REDIS_HOST_PORT}:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 20
    networks: [task-net]

  api:
    # Replace with your API image or a build: context. ./api is the task's
    # worktree of the repo whose compose_role is 'api'.
    image: ${API_IMAGE:-alpine:3}
    restart: unless-stopped
    env_file: ./app.env
    ports:
      - "127.0.0.1:${API_HOST_PORT}:8080"
    working_dir: /app
    command: ["sh", "-c", "echo 'replace api command'; sleep infinity"]
    volumes:
      - ./api:/app
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks: [task-net]

  ui:
    image: node:20-alpine
    restart: unless-stopped
    ports:
      - "127.0.0.1:${UI_HOST_PORT}:5173"
    working_dir: /usr/src/app
    command: ["sh", "-c", "npm install --no-audit --no-fund && npm run dev -- --host 0.0.0.0"]
    volumes:
      - ./ui:/usr/src/app
      - ui-node-modules:/usr/src/app/node_modules
    networks: [task-net]

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "${NGINX_HOST_PORT}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on: [api, ui]
    networks: [task-net]

volumes:
  db-data:
  redis-data:
  ui-node-modules:

networks:
  task-net:
    driver: bridge
