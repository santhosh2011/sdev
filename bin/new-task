#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

PROJECT="$(require_project "$(resolve_project "${SDEV_PROJECT:-}")")"

usage() {
    cat <<EOF
Usage: new-task <slug> [--env local|dev|staging] [--repos api,ui] [--api-base qa] [--ui-base qa]
                       [--no-fetch] [--no-pool] [--lease [holder]]

Creates an isolated parallel-task workspace under projects/<project>/<slug>/.
Each repo's task branch starts from the latest origin/<base> (fetched first);
pass --no-fetch to skip the fetch and use whatever the source repo already has.

Warm pool: if a matching worktree was returned by 'sdev end --pool', it is
reused (deps/build caches intact) and re-branded to task/<slug>; pass --no-pool
to always create fresh. --lease reserves the task durably (a background agent
holding it across sessions is never auto-reclaimed).
EOF
}

SLUG=""
REPOS_ARG=""
ENV_PROFILE=""
FETCH=1
USE_POOL=1
LEASE=0
LEASE_HOLDER=""
declare -A BASE_OVERRIDE=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --repos) REPOS_ARG="$2"; shift 2 ;;
        --env) ENV_PROFILE="$2"; shift 2 ;;
        --no-fetch) FETCH=0; shift ;;
        --no-pool) USE_POOL=0; shift ;;
        --lease)
            LEASE=1; shift
            # optional holder label (anything not starting with '-')
            if [[ $# -gt 0 && "$1" != -* ]]; then LEASE_HOLDER="$1"; shift; fi
            ;;
        --*-base)
            key="${1#--}"; key="${key%-base}"
            BASE_OVERRIDE[$key]="$2"
            shift 2
            ;;
        --*) die "unknown flag: $1" ;;
        *) [[ -z "$SLUG" ]] && SLUG="$1" || die "unexpected arg: $1"; shift ;;
    esac
done
[[ -z "$LEASE_HOLDER" ]] && LEASE_HOLDER="${SDEV_LEASE_HOLDER:-}"

[[ -n "$SLUG" ]] || { usage; die "slug required"; }
validate_slug "$SLUG" || die "invalid slug '$SLUG' — must be kebab-case, 1-50 chars"

TASK_DIR="$SDEV_HOME/projects/$PROJECT/$SLUG"
[[ -e "$TASK_DIR" ]] && die "projects/$PROJECT/$SLUG already exists"
[[ -e "$SDEV_HOME/projects/_archive/$PROJECT/$SLUG" ]] && die "archived task projects/_archive/$PROJECT/$SLUG exists — restore or pick another slug"

PROFILE="$(resolve_profile_for_new "$ENV_PROFILE")"
log "slug=$SLUG"
log "env profile=$PROFILE"

# Determine which repos to include.
ALL_REPOS=()
while read -r r; do ALL_REPOS+=("$r"); done < <(config_repos "$PROJECT")

if [[ -n "$REPOS_ARG" ]]; then
    IFS=',' read -ra SELECTED <<< "$REPOS_ARG"
else
    SELECTED=("${ALL_REPOS[@]}")
fi

for r in "${SELECTED[@]}"; do
    printf '%s\n' "${ALL_REPOS[@]}" | grep -qx "$r" || die "unknown repo '$r' (allowed: ${ALL_REPOS[*]})"
done

mkdir -p "$TASK_DIR"

CREATED=()
rollback() {
    for w in "${CREATED[@]}"; do
        local rp src
        rp="$(config_repo_path "$PROJECT" "$w")"
        src="$(repo_source_dir "$PROJECT" "$rp")"
        git -C "$src" worktree remove --force "$TASK_DIR/$rp" 2>/dev/null || true
        git -C "$src" branch -D "task/$SLUG" 2>/dev/null || true
    done
    rm -rf "$TASK_DIR"
    log "rolled back"
}
trap 'rollback' ERR

for r in "${SELECTED[@]}"; do
    repo_path="$(config_repo_path "$PROJECT" "$r")"
    base="${BASE_OVERRIDE[$r]:-$(config_repo_base "$PROJECT" "$r")}"
    src="$(repo_source_dir "$PROJECT" "$repo_path")"
    [[ -d "$src/.git" || -f "$src/.git" ]] || die "$repo_path: no git source at $src"

    # Refresh the base from origin so the task starts on the latest (unless --no-fetch).
    if [[ $FETCH -eq 1 ]]; then
        if git -C "$src" fetch --quiet origin "$base" 2>/dev/null; then
            log "fetched origin/$base for $repo_path"
        else
            log "warning: $repo_path: fetch of '$base' from origin failed — base may be stale"
        fi
    fi

    # Start the task branch from the freshest base available: prefer the remote
    # tip (origin/<base>), else a local branch. --no-track keeps task/<slug> from
    # adopting the base as its upstream.
    if git -C "$src" show-ref --verify --quiet "refs/remotes/origin/$base"; then
        start_point="origin/$base"
    elif git -C "$src" show-ref --verify --quiet "refs/heads/$base"; then
        start_point="$base"
    else
        die "$repo_path: base branch '$base' not found locally or on origin"
    fi
    mkdir -p "$(dirname "$TASK_DIR/$repo_path")"

    # Warm pool: reuse a returned worktree for this source if one exists.
    # Re-brand it to task/<slug> at the fresh start point (tracked files reset,
    # gitignored deps/build caches preserved). Fall back to a fresh worktree on
    # any hiccup or an empty pool.
    reused=0
    if [[ $USE_POOL -eq 1 ]]; then
        pooled="$(pool_take "$src")"
        if [[ -n "$pooled" ]]; then
            if [[ -d "$pooled" ]] \
               && git -C "$src" worktree move "$pooled" "$TASK_DIR/$repo_path" 2>/dev/null \
               && git -C "$TASK_DIR/$repo_path" checkout --no-track -B "task/$SLUG" "$start_point" >/dev/null 2>&1; then
                reused=1
                log "reused pooled worktree for $r ($repo_path) -> task/$SLUG"
            else
                # Reuse failed — discard the stale slot and create fresh below.
                git -C "$src" worktree remove --force "$TASK_DIR/$repo_path" 2>/dev/null || true
                rm -rf "${pooled:?}" "${TASK_DIR:?}/$repo_path" 2>/dev/null || true
                log "warning: pooled reuse failed for $r — creating fresh"
            fi
        fi
    fi

    if [[ $reused -eq 0 ]]; then
        log "creating worktree $r ($repo_path) on branch task/$SLUG from $start_point"
        git -C "$src" worktree add --no-track \
            "$TASK_DIR/$repo_path" \
            -b "task/$SLUG" "$start_point" >/dev/null
    fi
    CREATED+=("$r")
done

trap - ERR
log "worktrees created: ${CREATED[*]}"

# Reserve a port offset from the central ledger under the state lock. The task
# dir already exists (created above) so a concurrent `sdev new` reconciling the
# ledger keeps this reservation — this is what closes the old scan race.
OFFSET="$(allocate_offset "$PROJECT/$SLUG" "$LEASE" "$LEASE_HOLDER")" \
    || die "could not allocate a port offset (state lock or ledger error)"
[[ -n "$OFFSET" ]] || die "port offset allocation returned empty"
log "port offset=$OFFSET"
[[ $LEASE -eq 1 ]] && log "leased${LEASE_HOLDER:+ to $LEASE_HOLDER}"

env_file="$TASK_DIR/.env"
{
    echo "COMPOSE_PROJECT_NAME=$PROJECT-$SLUG"
    echo "PORT_OFFSET=$OFFSET"
    echo "APP_ENV=$PROFILE"
    while read -r svc; do
        base="$(config_base_port "$PROJECT" "$svc")"
        var_name="$(echo "$svc" | tr '[:lower:]-' '[:upper:]_')_HOST_PORT"
        echo "${var_name}=$((base + OFFSET))"
    done < <(config_stack_services "$PROJECT")
    echo ""
    echo "# App runtime config comes from ./app.env (symlink -> $(profile_conf_file "$PROFILE" "$PROJECT"))"
} > "$env_file"

conf="$(profile_conf_file "$PROFILE" "$PROJECT")"
ln -sf "$conf" "$TASK_DIR/app.env"
[[ -f "$conf" ]] || log "warning: $conf does not exist — create it before 'sdev up'"

cp "$(config_template "$PROJECT")" "$TASK_DIR/docker-compose.yml"
cp "$SCRIPT_DIR/templates/compose.tmpl" "$TASK_DIR/compose"
chmod +x "$TASK_DIR/compose"

# Service pruning — ONLY for the default template.
if config_uses_default_template "$PROJECT"; then
    if ! printf '%s\n' "${SELECTED[@]}" | grep -qx ui; then
        yq -i 'del(.services.ui) | del(.services.nginx) | del(.volumes."ui-node-modules")' "$TASK_DIR/docker-compose.yml"
    fi
    if printf '%s\n' "${SELECTED[@]}" | grep -qx ui; then
        cp "$SCRIPT_DIR/templates/nginx.conf.tmpl" "$TASK_DIR/nginx.conf"
    fi
fi

# node_modules — generic per-repo.
for r in "${SELECTED[@]}"; do
    [[ "$(config_repo_attr "$PROJECT" "$r" link_node_modules)" == "true" ]] || continue
    rp="$(config_repo_path "$PROJECT" "$r")"
    src_nm="$(repo_source_dir "$PROJECT" "$rp")/node_modules"
    if [[ -d "$src_nm" ]]; then
        ln -sfn "$src_nm" "$TASK_DIR/$rp/node_modules"   # -f/-n: idempotent on pool reuse
    else
        log "warning: $src_nm missing — run npm install in the source repo first"
    fi
    cat > "$TASK_DIR/$rp/.npmrc" <<'EOF'
# Do NOT run `npm install` here — node_modules is symlinked to the source repo.
# Installing here pollutes the shared source. Add deps in the source repo.
EOF
done

mkdir -p "$TASK_DIR/knowledge"

nginx_port="$(grep '^NGINX_HOST_PORT=' "$env_file" | cut -d= -f2 || true)"
api_port="$(grep '^API_HOST_PORT=' "$env_file" | cut -d= -f2 || true)"
ui_port="$(grep '^UI_HOST_PORT=' "$env_file" | cut -d= -f2 || true)"
db_port="$(grep '^DB_HOST_PORT=' "$env_file" | cut -d= -f2 || true)"
redis_port="$(grep '^REDIS_HOST_PORT=' "$env_file" | cut -d= -f2 || true)"

claude_md="$TASK_DIR/CLAUDE.md"
sed \
    -e "s/__SLUG__/$SLUG/g" \
    -e "s/__PROJECT__/$PROJECT/g" \
    -e "s/__APP_ENV__/$PROFILE/g" \
    -e "s/__NGINX_HOST_PORT__/${nginx_port:-N\/A}/g" \
    -e "s/__API_HOST_PORT__/${api_port:-N\/A}/g" \
    -e "s/__UI_HOST_PORT__/${ui_port:-N\/A}/g" \
    -e "s/__DB_HOST_PORT__/${db_port:-N\/A}/g" \
    -e "s/__REDIS_HOST_PORT__/${redis_port:-N\/A}/g" \
    "$SCRIPT_DIR/templates/CLAUDE.md.tmpl" \
    > "$claude_md"

if [[ "$PROFILE" == staging ]]; then
    tmp="$(mktemp)"
    {
        printf '> \xf0\x9f\x94\xb4 **STAGING ENVIRONMENT** — this task targets your real staging environment.\n'
        printf '> It can read/write REAL staging data. Double-check before running mutations.\n\n'
        cat "$claude_md"
    } > "$tmp"
    mv "$tmp" "$claude_md"
fi

mkdir -p "$TASK_DIR/.claude"
settings_file="$TASK_DIR/.claude/settings.local.json"
hooks_dir="$SDEV_INSTALL/claude/hooks"
if config_hooks_enabled "$PROJECT" && [[ -d "$hooks_dir" ]]; then
    SC="$hooks_dir/sdev-session-context" \
    SG="$hooks_dir/sdev-staging-guard" \
    ER="$hooks_dir/sdev-edit-reminder" \
    yq -n -o=json '
      .additionalDirectories = [] |
      .hooks.SessionStart = [{"matcher": "startup|resume", "hooks": [{"type": "command", "command": strenv(SC)}]}] |
      .hooks.PreToolUse   = [{"matcher": "Bash",           "hooks": [{"type": "command", "command": strenv(SG)}]}] |
      .hooks.PostToolUse  = [{"matcher": "Edit|Write",     "hooks": [{"type": "command", "command": strenv(ER)}]}]
    ' > "$settings_file"
else
    cp "$SCRIPT_DIR/templates/settings.local.json.tmpl" "$settings_file"
fi

cat <<EOF

next steps:
  cd projects/$PROJECT/$SLUG
  ./compose up
  # open http://localhost:${nginx_port:-?}/
  claude

ports allocated (offset=$OFFSET): nginx=${nginx_port:-N/A} api=${api_port:-N/A} ui=${ui_port:-N/A} db=${db_port:-N/A} redis=${redis_port:-N/A}
EOF
