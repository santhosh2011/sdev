# Example runtime env for the 'example' project, 'local' profile.
# Real conf files live at confs/<project>/<conf_prefix>.<profile>.env and are
# gitignored. Copy this to confs/example/app.local.env and fill in.
APP_ENV=local
# DATABASE_URL=postgres://app:app@db:5432/app
# REDIS_URL=redis://redis:6379/0
