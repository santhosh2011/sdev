#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
# VERSION carries a release-please annotation comment (# x-release-please-version);
# strip it so builds get a clean bare semver.
VERSION="$(sed -E 's/[[:space:]]*#.*$//' "$REPO_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
VERSION="${VERSION:-0.0.0}"
OUT_DIR="${1:-$REPO_DIR/build}"

STAGE="$(mktemp -d)"
trap 'rm -rf "$STAGE"' EXIT
PKG="$STAGE/sdev"
mkdir -p "$PKG"

# Tool code + top-level reference assets.
cp -R "$REPO_DIR/bin" "$PKG/bin"
# Don't ship a locally-built dev binary; install selects a per-platform one below.
rm -f "$PKG/bin/sdev-go"

# Cross-compile the native Go binary for each supported platform. Users get a
# single dependency-free binary (install picks the host one); no Go toolchain is
# needed at install time. Degrades gracefully to the bash runtime if go is absent.
# dist prints only the zip path on stdout (tests capture it), so stay silent here.
if command -v go >/dev/null 2>&1 && [[ -d "$REPO_DIR/go" ]]; then
    for pair in darwin/amd64 darwin/arm64 linux/amd64 linux/arm64; do
        goos="${pair%/*}"; goarch="${pair#*/}"
        ( cd "$REPO_DIR/go" && GOOS="$goos" GOARCH="$goarch" CGO_ENABLED=0 \
            go build -trimpath -ldflags "-s -w" -o "$PKG/bin/sdev-$goos-$goarch" ./cmd/sdev )
    done
fi
cp "$REPO_DIR/install" "$PKG/install"
# Distribution helpers: the network installer + self-update engine.
for s in install.sh self-update; do
    [[ -f "$REPO_DIR/$s" ]] && { cp "$REPO_DIR/$s" "$PKG/$s"; chmod +x "$PKG/$s"; }
done
for f in README.md LICENSE; do
    [[ -f "$REPO_DIR/$f" ]] && cp "$REPO_DIR/$f" "$PKG/$f"
done
# Ship a clean, bare VERSION (no release-please annotation) to end users.
printf '%s\n' "$VERSION" > "$PKG/VERSION"

# core/: ship ONLY the default config + example registry — no personal projects, no clones.
mkdir -p "$PKG/core/projects.d"
cp "$REPO_DIR/core/.task-config.yml" "$PKG/core/.task-config.yml"
cp "$REPO_DIR/core/projects.d/example.yml" "$PKG/core/projects.d/example.yml"

# confs/: ship ONLY *.example files — never real env files.
if [[ -d "$REPO_DIR/confs" ]]; then
    while IFS= read -r f; do
        rel="${f#"$REPO_DIR"/}"
        mkdir -p "$PKG/$(dirname "$rel")"
        cp "$f" "$PKG/$rel"
    done < <(find "$REPO_DIR/confs" -type f -name '*.example')
fi

# claude/: optional Claude Code skill + slash-command (tool-owned).
if [[ -d "$REPO_DIR/claude" ]]; then
    cp -R "$REPO_DIR/claude" "$PKG/claude"
fi

mkdir -p "$OUT_DIR"
ZIP="$(cd "$OUT_DIR" && pwd)/sdev-$VERSION.zip"
rm -f "$ZIP"
( cd "$STAGE" && zip -rq "$ZIP" sdev )

# Integrity checksum for the published zip.
( cd "$(dirname "$ZIP")" && shasum -a 256 "$(basename "$ZIP")" > "$(basename "$ZIP").sha256" )

echo "$ZIP"
