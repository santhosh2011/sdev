#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

SCOPE_PROJECT=""
JSON=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --project) SCOPE_PROJECT="$2"; shift 2 ;;
        --json) JSON=1; shift ;;
        *) shift ;;
    esac
done

# Running-container count for a compose project name (0 when none / docker absent).
lt_running() {   # $1=compose_project_name
    { docker ps --filter "label=com.docker.compose.project=$1" -q 2>/dev/null || true; } | wc -l | tr -d ' '
}

# ---- machine-readable output (opt-in) -----------------------------------------
if [[ "$JSON" -eq 1 ]]; then
    alive="[]"; archived="[]"; orphans="[]"; running_total=0
    shopt -s nullglob

    add_alive() {   # $1=label $2=envfile
        local env="$2" np off cpn running status url
        np="$(grep '^NGINX_HOST_PORT=' "$env" | cut -d= -f2 || true)"
        off="$(grep '^PORT_OFFSET=' "$env" | cut -d= -f2 || true)"
        cpn="$(grep '^COMPOSE_PROJECT_NAME=' "$env" | cut -d= -f2 || true)"
        [[ -z "$cpn" ]] && cpn="$1"
        running="$(lt_running "$cpn")"
        status="stopped"; [[ "${running:-0}" -gt 0 ]] && status="running"
        url=""; [[ -n "$np" ]] && url="http://localhost:$np/"
        running_total=$((running_total + running))
        alive="$(jq -c --arg t "$1" --argjson off "${off:-0}" --argjson port "${np:-0}" \
            --arg url "$url" --argjson running "$running" --arg status "$status" \
            '. + [{task:$t, offset:$off, nginx_port:$port, url:$url, running:$running, status:$status}]' <<<"$alive")"
    }
    add_archived() {   # $1=label $2=dir
        local date
        date="$(grep '^- archive_date:' "$2/ARCHIVE_INFO.md" 2>/dev/null | cut -d: -f2- | xargs || true)"
        archived="$(jq -c --arg t "$1" --arg d "$date" '. + [{task:$t, archived:$d}]' <<<"$archived")"
    }

    for pdir in "$SDEV_HOME"/projects/*/; do
        name="$(basename "$pdir")"
        [[ "$name" == "_archive" ]] && continue
        if [[ -f "$pdir/.env" ]]; then
            [[ -n "$SCOPE_PROJECT" && "$SCOPE_PROJECT" != "default" ]] && continue
            add_alive "$name" "$pdir/.env"; continue
        fi
        [[ -n "$SCOPE_PROJECT" && "$SCOPE_PROJECT" != "$name" ]] && continue
        for tdir in "$pdir"*/; do
            [[ -f "$tdir/.env" ]] || continue
            add_alive "$name/$(basename "$tdir")" "$tdir/.env"
        done
    done

    for adir in "$SDEV_HOME"/projects/_archive/*/; do
        name="$(basename "$adir")"
        if [[ -f "$adir/ARCHIVE_INFO.md" ]]; then
            add_archived "$name" "$adir"; continue
        fi
        for tdir in "$adir"*/; do
            [[ -d "$tdir" ]] || continue
            add_archived "$name/$(basename "$tdir")" "$tdir"
        done
    done

    known=$(ls -1 "$SDEV_HOME/projects/" "$SDEV_HOME/projects/_archive/" 2>/dev/null | sort -u | grep -v '^_archive$' || true)
    while read -r vol; do
        [[ -z "$vol" ]] && continue
        proj="${vol%%_*}"
        if ! grep -qx "$proj" <<< "$known"; then
            orphans="$(jq -c --arg v "$vol" '. + [$v]' <<<"$orphans")"
        fi
    done < <(docker volume ls --format '{{.Name}}' 2>/dev/null || true)

    jq -n --arg project "${SCOPE_PROJECT:-}" \
        --argjson alive "$alive" --argjson archived "$archived" --argjson orphans "$orphans" \
        --argjson running "$running_total" \
        '{project: (if $project == "" then null else $project end),
          alive: $alive, archived: $archived, orphan_volumes: $orphans,
          totals: {alive: ($alive|length), archived: ($archived|length),
                   orphans: ($orphans|length), running: $running}}'
    exit 0
fi

echo "=== Alive tasks ==="
shopt -s nullglob
found=0
print_task() {
    local label="$1" env="$2"
    local nginx_port offset running status cpn
    nginx_port="$(grep '^NGINX_HOST_PORT=' "$env" | cut -d= -f2 || echo '-')"
    offset="$(grep '^PORT_OFFSET=' "$env" | cut -d= -f2 || echo '-')"
    cpn="$(grep '^COMPOSE_PROJECT_NAME=' "$env" | cut -d= -f2 || echo "$label")"
    running="$({ docker ps --filter "label=com.docker.compose.project=$cpn" -q 2>/dev/null || true; } | wc -l | tr -d ' ')"
    status="stopped"; [[ "${running:-0}" -gt 0 ]] && status="running ($running containers)"
    printf "  %-28s offset=%-3s nginx=http://localhost:%-5s [%s]\n" "$label" "$offset" "${nginx_port:-N/A}" "$status"
}
for pdir in "$SDEV_HOME"/projects/*/; do
    name="$(basename "$pdir")"
    [[ "$name" == "_archive" ]] && continue
    if [[ -f "$pdir/.env" ]]; then
        # legacy flat task (treated as the implicit 'default' project)
        [[ -n "$SCOPE_PROJECT" && "$SCOPE_PROJECT" != "default" ]] && continue
        found=1; print_task "$name (legacy)" "$pdir/.env"
        continue
    fi
    # namespaced project dir
    [[ -n "$SCOPE_PROJECT" && "$SCOPE_PROJECT" != "$name" ]] && continue
    for tdir in "$pdir"*/; do
        [[ -f "$tdir/.env" ]] || continue
        found=1; print_task "$name/$(basename "$tdir")" "$tdir/.env"
    done
done
[[ $found -eq 0 ]] && echo "  (none)"

echo
echo "=== Archived tasks ==="
found=0
print_archived() {
    local label="$1" dir="$2"
    local date
    date="$(grep '^- archive_date:' "$dir/ARCHIVE_INFO.md" 2>/dev/null | cut -d: -f2- | xargs || echo '-')"
    printf "  %-28s archived %s\n" "$label" "$date"
}
for adir in "$SDEV_HOME"/projects/_archive/*/; do
    name="$(basename "$adir")"
    if [[ -f "$adir/ARCHIVE_INFO.md" ]]; then
        found=1; print_archived "$name (legacy)" "$adir"
        continue
    fi
    for tdir in "$adir"*/; do
        [[ -d "$tdir" ]] || continue
        found=1; print_archived "$name/$(basename "$tdir")" "$tdir"
    done
done
[[ $found -eq 0 ]] && echo "  (none)"

echo
echo "=== Orphan docker volumes ==="
known=$(ls -1 "$SDEV_HOME/projects/" "$SDEV_HOME/projects/_archive/" 2>/dev/null | sort -u | grep -v '^_archive$' || true)
orphans=0
while read -r vol; do
    [[ -z "$vol" ]] && continue
    proj="${vol%%_*}"
    if ! grep -qx "$proj" <<< "$known"; then
        echo "  $vol"
        orphans=$((orphans+1))
    fi
done < <(docker volume ls --format '{{.Name}}' 2>/dev/null || true)
if [[ $orphans -eq 0 ]]; then echo "  (none)"; fi
