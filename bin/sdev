#!/usr/bin/env bash
set -euo pipefail

# Resolve script dir, following symlinks (so a personal alias symlink still works).
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

# ---- project pre-parse (before subcommand) ------------------------------------
PROJECT_FLAG=""
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--project) [[ $# -ge 2 ]] || die "-p/--project requires a project name"; PROJECT_FLAG="$2"; shift 2 ;;
        *) ARGS+=("$1"); shift ;;
    esac
done
set -- "${ARGS[@]:-}"
[[ -z "${1:-}" ]] && set --   # normalize empty

usage() {
    cat <<EOF
sdev - run many isolated, parallel dev workspaces side by side. Each task is a git
       worktree + its own docker stack on unique ports, so you (or a fleet of agents)
       work on many branches at once without collisions. Grouped by project;
       one command creates a task, boots it, and gives you a URL.

Usage: sdev [-p <project>] <command> [args…]
       sdev <slug>                # shorthand for: sdev new <slug>

Project:
  use [<project>]                 pin active project for this terminal (no arg: show)
  projects                        list defined projects
  -p <project>                    override active project for one command

Commands:
  new <slug> [flags…]             create a new task workspace
  start <slug> [flags…]           front door: create-or-resume + boot + open (accepts new flags; --no-open, --json)
  review <slug> [--no-open]       render the task diff as an annotatable lavish surface (--json)
  ship <slug> [flags…]            push task branch(es) + open PR (assignee set); --assignee, --force, --json
  up <slug> [extra…]              start the stack (docker-compose up -d)
  down <slug>                     stop the stack (docker-compose down)
  nuke <slug>                     stop + reclaim volumes (down -v --remove-orphans)
  end <slug> [--pool] [flags…]    tear down + archive (or return worktree to pool)
  destroy <slug> [--force]        force-remove a task (worktree + offset + entry; no archive)
  prune [--apply] [--pool]        reclaim ephemeral/abandoned slots; --pool drains the warm pool
  lease <slug> [holder]           durably reserve a task (survives with no process)
  release <slug>                  drop a task's lease + process-lock
  hold <slug> [--pid N]           attach a self-healing process-lock (default: this shell)
  new <slug> --ephemeral          create a short-lived, auto-reclaimable task
  doctor                          check deps + state-ledger integrity
  ls | list [--json]              list alive / archived / orphan tasks
  status [--json]                 fleet overview across all projects
  ps <slug> [--json]              compose ps for a task
  logs <slug> [service…]          tail logs (-f); pass --no-follow to disable
  shell <slug> [service]          exec sh in service (default: project's shell service)
  open <slug>                     open http://localhost:<nginx-port>/ in browser
  code <slug>                     open the task dir in Zed
  cd <slug>                       print absolute task dir (use: cd "\$(sdev cd <slug>)")
  init                            interactive wizard to configure your first project
  edit [<project>] [--delete-source]   add/remove repos, edit conf/shell/stack
  migrate --from <dir>            move an old in-repo sdev layout into \$SDEV_HOME
  update                          fetch the latest release and reinstall in place
  help | -h | --help              show this help
EOF
}

# Subcommand keywords (reserved — slugs cannot collide).
is_reserved() {
    case "$1" in
        new|start|up|down|nuke|end|review|ship|destroy|prune|lease|release|hold|doctor|ls|list|ps|logs|shell|open|code|cd|use|projects|status|init|edit|migrate|update|help|-h|--help) return 0 ;;
        *) return 1 ;;
    esac
}

# Ledger key for a resolved task dir: projects/-relative ("<project>/<slug>" or
# legacy "<slug>"). Matches how new-task/end-task key the ledger.
task_key_for_dir() { echo "${1#"$SDEV_HOME"/projects/}"; }

require_task_dir() {
    local slug="$1"
    [[ -n "$slug" ]] || die "slug required"
    local ns="$SDEV_HOME/projects/$PROJECT/$slug"
    [[ -d "$ns" ]] && { echo "$ns"; return; }
    local flat="$SDEV_HOME/projects/$slug"
    [[ -d "$flat" ]] && { echo "$flat"; return; }
    die "task '$slug' not found in project '$PROJECT' (or legacy projects/$slug)"
}

# ---- dispatch -----------------------------------------------------------------

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

CMD="$1"; shift
PROJECT="$(resolve_project "$PROJECT_FLAG")"

# If first arg isn't a reserved keyword, treat as implicit `new <slug>`.
if ! is_reserved "$CMD"; then
    exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/new-task" "$CMD" "$@"
fi

# If the Go binary is built, exec it for this subcommand (never returns); else
# return so the caller's bash fallback runs. Strangler seam: the tool keeps
# working with no Go toolchain installed.
try_go() {   # $1=go subcommand, rest=args
    [[ -x "$SCRIPT_DIR/sdev-go" ]] || return 0
    exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/sdev-go" "$@"
}

# Exec a ported subcommand: the Go binary when built, else a bash fallback script.
run_ported() {   # $1=go subcommand, $2=bash fallback script, rest=args
    local sub="$1" fallback="$2"; shift 2
    try_go "$sub" "$@"
    exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/$fallback" "$@"
}

case "$CMD" in
    help|-h|--help)
        usage
        ;;
    new)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/new-task" "$@"
        ;;
    start)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/start" "$@"
        ;;
    review)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/review" "$@"
        ;;
    ship)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/ship" "$@"
        ;;
    end)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/end-task" "$@"
        ;;
    destroy)
        # Force-remove a specific task: worktree + branch + docker + offset +
        # ledger entry. No archive, no pool, no pre-flight. Refuses a task with a
        # live lease or live process-lock unless --force. Also handles a
        # workspace-less entry (e.g. a lease whose worktree is already gone).
        slug=""; force=0
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --force|-f) force=1; shift ;;
                *) [[ -z "$slug" ]] && slug="$1" || die "unexpected arg: $1"; shift ;;
            esac
        done
        [[ -n "$slug" ]] || die "slug required"
        # Resolve the ledger key: prefer an on-disk workspace, else a bare entry.
        if [[ -d "$SDEV_HOME/projects/$PROJECT/$slug" ]]; then key="$PROJECT/$slug"
        elif [[ -d "$SDEV_HOME/projects/$slug" ]]; then key="$slug"
        elif [[ -f "$STATE_FILE" && "$(K="$PROJECT/$slug" yq -r '.tasks | has(strenv(K))' "$STATE_FILE" 2>/dev/null)" == "true" ]]; then key="$PROJECT/$slug"
        elif [[ -f "$STATE_FILE" && "$(K="$slug" yq -r '.tasks | has(strenv(K))' "$STATE_FILE" 2>/dev/null)" == "true" ]]; then key="$slug"
        else die "task '$slug' not found (no workspace or ledger entry in project '$PROJECT')"; fi
        if [[ $force -eq 0 ]]; then
            st="$(_task_reservation_state "$key")"
            case "$st" in
                leased) die "$key holds a live lease — 'sdev release $slug' first, or pass --force" ;;
                locked) die "$key holds a live process-lock — pass --force to destroy anyway" ;;
            esac
        fi
        force_teardown_task "$key"
        log "destroyed $key (worktree + offset + ledger entry removed)"
        ;;
    prune)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/prune" "$@"
        ;;
    lease)
        try_go lease "$@"
        slug="${1:-}"; shift || true
        holder="${1:-${SDEV_LEASE_HOLDER:-}}"
        dir="$(require_task_dir "$slug")"
        key="$(task_key_for_dir "$dir")"
        set_lease "$key" "$holder"
        log "leased $key${holder:+ to $holder} (durable — not auto-reclaimed until 'sdev release')"
        ;;
    release)
        try_go release "$@"
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        key="$(task_key_for_dir "$dir")"
        clear_reservation "$key"
        log "released $key (lease + process-lock cleared)"
        ;;
    hold)
        try_go hold "$@"
        slug=""; pid=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --pid) pid="$2"; shift 2 ;;
                *) [[ -z "$slug" ]] && slug="$1" || die "unexpected arg: $1"; shift ;;
            esac
        done
        dir="$(require_task_dir "$slug")"
        key="$(task_key_for_dir "$dir")"
        # Default to the invoking shell ($PPID) — a long-lived owner whose death
        # makes the lock self-heal. proc_token pins the identity against PID reuse.
        [[ -z "$pid" ]] && pid="$PPID"
        [[ "$pid" =~ ^[0-9]+$ ]] || die "invalid --pid '$pid'"
        set_lock "$key" "$pid" "$(_proc_token "$pid")"
        log "process-lock on $key held by pid $pid (self-heals when it exits)"
        ;;
    doctor)
        run_ported doctor doctor "$@"
        ;;
    init)
        exec "$SCRIPT_DIR/init"
        ;;
    edit)
        exec env SDEV_PROJECT="$PROJECT" "$SCRIPT_DIR/edit-project" "$@"
        ;;
    migrate)
        exec "$SCRIPT_DIR/migrate" "$@"
        ;;
    update)
        # self-update ships at the install-dir root (parent of bin/).
        updater="$SCRIPT_DIR/../self-update"
        [[ -x "$updater" ]] || die "self-update not found at $updater (reinstall sdev)"
        exec "$updater" "$@"
        ;;
    ls|list)
        # shellcheck disable=SC2086
        run_ported ls list-tasks ${PROJECT_FLAG:+--project "$PROJECT_FLAG"} "$@"
        ;;
    status)
        run_ported status status "$@"
        ;;
    up)
        slug=""; profile_flag=""; assume_yes=0
        extra=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --env) profile_flag="$2"; shift 2 ;;
                --yes|-y) assume_yes=1; shift ;;
                *) if [[ -z "$slug" ]]; then slug="$1"; else extra+=("$1"); fi; shift ;;
            esac
        done
        dir="$(require_task_dir "$slug")"

        # Optional switch: re-point app.env + rewrite APP_ENV.
        if [[ -n "$profile_flag" ]]; then
            is_valid_profile "$profile_flag" || die "invalid env profile '$profile_flag' (allowed: ${VALID_PROFILES[*]})"
            ln -sf "$(profile_conf_file "$profile_flag" "$PROJECT")" "$dir/app.env"
            if grep -qE '^APP_ENV=' "$dir/.env" 2>/dev/null; then
                sed -i.bak -E "s/^APP_ENV=.*/APP_ENV=$profile_flag/" "$dir/.env" && rm -f "$dir/.env.bak"
            else
                echo "APP_ENV=$profile_flag" >> "$dir/.env"
            fi
        fi

        profile="$(task_pinned_profile "$dir")"; profile="${profile:-local}"

        # Staging guard: never implicit.
        if [[ "$profile" == staging ]]; then
            if [[ "$assume_yes" -eq 1 || "${SDEV_CONFIRM:-}" == staging ]]; then
                log "staging confirmed (non-interactive)"
            else
                echo "⚠️  STAGING — this task targets your real staging environment." >&2
                echo "    It can read/write REAL staging data." >&2
                printf "    Type 'staging' to continue: " >&2
                read -r ans || ans=""
                [[ "$ans" == staging ]] || die "aborted (staging not confirmed)"
            fi
        fi

        cd "$dir"
        exec ./compose up -d "${extra[@]}"
        ;;
    down)
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        cd "$dir"
        exec ./compose down "$@"
        ;;
    nuke)
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        cd "$dir"
        exec ./compose down -v --remove-orphans
        ;;
    ps)
        try_go ps "$@"
        json=0; slug=""; extra=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --json) json=1; shift ;;
                *) if [[ -z "$slug" ]]; then slug="$1"; else extra+=("$1"); fi; shift ;;
            esac
        done
        dir="$(require_task_dir "$slug")"
        if [[ "$json" -eq 1 ]]; then
            rel="${dir#"$SDEV_HOME"/projects/}"
            port="$(grep '^NGINX_HOST_PORT=' "$dir/.env" 2>/dev/null | cut -d= -f2 || true)"
            url=""; [[ -n "$port" ]] && url="http://localhost:$port/"
            raw="$(cd "$dir" && ./compose ps --format json 2>/dev/null || true)"
            services="$(printf '%s\n' "$raw" | jq -sc '
                [ .[] | if type == "array" then .[] else . end ]
                | [ .[] | {name: (.Service // .Name // ""), state: (.State // .Status // ""),
                           ports: ([ (.Publishers // [])[] | select((.PublishedPort // 0) > 0)
                                     | "\(.PublishedPort)->\(.TargetPort)" ]) } ]' 2>/dev/null || echo '[]')"
            [[ -n "$services" ]] || services="[]"
            jq -n --arg task "$rel" --arg url "$url" --argjson services "$services" \
                '{task: $task, url: $url, services: $services}'
            exit 0
        fi
        cd "$dir"
        exec ./compose ps "${extra[@]}"
        ;;
    logs)
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        follow=1
        services=()
        for arg in "$@"; do
            if [[ "$arg" == "--no-follow" ]]; then
                follow=0
            else
                services+=("$arg")
            fi
        done
        cd "$dir"
        if [[ $follow -eq 1 ]]; then
            exec ./compose logs -f "${services[@]}"
        else
            exec ./compose logs "${services[@]}"
        fi
        ;;
    shell)
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        svc="${1:-$(config_shell_service "$PROJECT")}"
        cd "$dir"
        exec ./compose exec -it "$svc" sh
        ;;
    open)
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        env_file="$dir/.env"
        [[ -f "$env_file" ]] || die "$env_file not found"
        port="$(grep '^NGINX_HOST_PORT=' "$env_file" | cut -d= -f2 || true)"
        [[ -n "$port" ]] || die "NGINX_HOST_PORT not set in $env_file"
        url="http://localhost:$port/"
        if command -v open >/dev/null 2>&1; then
            open "$url"
        else
            echo "$url"
        fi
        ;;
    cd)
        slug="${1:-}"; shift || true
        require_task_dir "$slug"
        ;;
    code)
        slug="${1:-}"; shift || true
        dir="$(require_task_dir "$slug")"
        # Prefer $VISUAL/$EDITOR, then common editor CLIs; fall back to printing the path.
        if [[ -n "${VISUAL:-}" ]]; then
            exec $VISUAL "$dir"
        elif [[ -n "${EDITOR:-}" ]]; then
            exec $EDITOR "$dir"
        elif command -v zed >/dev/null 2>&1; then
            exec zed "$dir"
        elif command -v code >/dev/null 2>&1; then
            exec code "$dir"
        elif command -v cursor >/dev/null 2>&1; then
            exec cursor "$dir"
        else
            echo "No editor found. Set \$EDITOR/\$VISUAL, or open: $dir" >&2
            echo "$dir"
        fi
        ;;
    use)
        target="${1:-}"
        if [[ -z "$target" ]]; then
            cur="$(resolve_project "")"
            echo "active project: $cur (session: $(session_key))"
            exit 0
        fi
        target="$(require_project "$target")"
        mkdir -p "$(session_project_dir)"
        printf '%s\n' "$target" > "$(session_project_pointer)"
        log "pinned project '$target' for this terminal"
        ;;
    projects)
        printf "%-16s %-8s %-8s\n" PROJECT TASKS RUNNING
        for p in $(config_projects); do
            n=0
            shopt -s nullglob
            for d in "$SDEV_HOME"/projects/"$p"/*/; do
                [[ -f "$d/.env" ]] && n=$((n+1))
            done
            printf "%-16s %-8s %-8s\n" "$p" "$n" "-"
        done
        ;;
    *)
        usage
        die "unknown command: $CMD"
        ;;
esac
