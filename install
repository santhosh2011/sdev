#!/usr/bin/env bash
set -euo pipefail

# The unpacked tool dir (this script ships at the zip root).
SRC_DIR="$(cd "$(dirname "$0")" && pwd)"

INSTALL_DIR="${SDEV_INSTALL:-$HOME/.local/share/sdev}"
BIN_DIR="${SDEV_BIN_DIR:-$HOME/.local/bin}"
HOME_DIR=""   # resolved below (env override or interactive prompt)

say()  { printf '%s\n' "$*"; }
warn() { printf '%s\n' "$*" >&2; }

# Expand a leading ~ and make the path absolute (relative to $PWD).
expand_path() {
    local p="$1"
    # Match a literal leading tilde the user typed, then expand it to $HOME.
    # shellcheck disable=SC2088
    case "$p" in
        "~")    p="$HOME" ;;
        "~/"*)  p="$HOME/${p#\~/}" ;;
    esac
    case "$p" in /*) : ;; *) p="$PWD/$p" ;; esac
    printf '%s' "$p"
}

# Reject paths that are unsafe or unusable as a data home.
validate_home() {
    local p="$1"
    case "$p" in
        ""|"/"|"$HOME")
            warn "✗ '$p' is not a valid project home — choose a dedicated directory."; return 1 ;;
    esac
    if [[ -e "$p" && ! -d "$p" ]]; then
        warn "✗ '$p' exists and is not a directory."; return 1
    fi
    if ! mkdir -p "$p" 2>/dev/null; then
        warn "✗ cannot create '$p' (permission denied?)."; return 1
    fi
    if [[ ! -w "$p" ]]; then
        warn "✗ '$p' is not writable."; return 1
    fi
    return 0
}

# The shell rc file to persist exports into.
detect_rc() {
    case "$(basename "${SHELL:-sh}")" in
        zsh)  printf '%s' "$HOME/.zshrc" ;;
        bash) if [[ "${os:-}" == Darwin ]]; then printf '%s' "$HOME/.bash_profile"
              else printf '%s' "$HOME/.bashrc"; fi ;;
        *)    printf '%s' "$HOME/.profile" ;;
    esac
}

# Write SDEV_HOME (+ PATH if needed) into the user's rc, inside an idempotent marked block.
persist_rc() {
    local rc="$1" tmp
    local start="# >>> sdev >>>" end="# <<< sdev <<<"
    mkdir -p "$(dirname "$rc")"
    touch "$rc"
    # Warn about hand-written SDEV_HOME exports anywhere they commonly hide (outside our block).
    local f
    for f in "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.zshenv" \
             "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
        [[ -f "$f" ]] || continue
        if grep -Eq '^[[:space:]]*export[[:space:]]+SDEV_HOME' "$f" 2>/dev/null \
           && ! grep -qF "$start" "$f" 2>/dev/null; then
            warn "⚠️  hand-written SDEV_HOME export found in $f — remove it to avoid clashing with $rc."
        fi
    done
    if grep -qF "$start" "$rc" 2>/dev/null; then
        tmp="$(mktemp)"
        awk -v s="$start" -v e="$end" '
            $0==s {skip=1; next} skip && $0==e {skip=0; next} skip {next} {print}
        ' "$rc" > "$tmp" && cat "$tmp" > "$rc" && rm -f "$tmp"
    fi
    {
        printf '%s\n' "$start"
        printf 'export SDEV_HOME=%q\n' "$HOME_DIR"
        case ":$PATH:" in *":$BIN_DIR:"*) : ;; *) printf 'export PATH=%q:"$PATH"\n' "$BIN_DIR" ;; esac
        printf '%s\n' "$end"
    } >> "$rc"
    say "✓ wired exports into $rc — restart your shell or run: source $rc"
}

# Optionally install the sdev Claude Code skill + command into ~/.claude.
# SDEV_CLAUDE (1/true/yes/y = install, anything else = skip) wins; otherwise, on a
# real TTY with an existing ~/.claude, prompt. Never auto-installs uninvited, and
# only ever writes the two sdev-owned paths.
maybe_install_claude() {
    local src="$INSTALL_DIR/claude"
    [[ -d "$src" ]] || return 0
    local do_it=0 reply=""
    if [[ -n "${SDEV_CLAUDE:-}" ]]; then
        case "$SDEV_CLAUDE" in 1|true|yes|y|Y) do_it=1 ;; *) do_it=0 ;; esac
    elif [[ -t 0 && -d "$HOME/.claude" ]]; then
        printf 'Install sdev Claude Code skill + command into ~/.claude? [Y/n]: ' >&2
        IFS= read -r reply || reply=""
        case "$reply" in [Nn]*) do_it=0 ;; *) do_it=1 ;; esac
    fi
    [[ $do_it -eq 1 ]] || return 0
    mkdir -p "$HOME/.claude/skills" "$HOME/.claude/commands"
    rm -rf "${HOME:?}/.claude/skills/sdev"
    cp -R "$src/skills/sdev" "$HOME/.claude/skills/sdev"
    cp "$src/commands/sdev-start.md" "$HOME/.claude/commands/sdev-start.md"
    say "✓ installed sdev Claude skill + command into ~/.claude (skills/sdev, commands/sdev-start.md)"
    merge_global_staging_guard
}

# Idempotently merge ONLY the staging-guard PreToolUse hook into the user's
# global ~/.claude/settings.json. Non-destructive (preserves other settings and
# hooks), creates the file if absent. Requires yq.
merge_global_staging_guard() {
    local guard="$INSTALL_DIR/claude/hooks/sdev-staging-guard"
    [[ -f "$guard" ]] || return 0
    if ! command -v yq >/dev/null 2>&1; then
        warn "⚠️  yq missing — skipped the global sdev staging-guard hook."
        return 0
    fi
    local settings="$HOME/.claude/settings.json"
    mkdir -p "$HOME/.claude"
    [[ -f "$settings" ]] || printf '{}\n' > "$settings"
    # Append only if our guard command is not already registered.
    local present
    present="$(GUARD="$guard" yq -p=json -r \
        '[.hooks.PreToolUse[]?.hooks[]?.command] | contains([strenv(GUARD)])' \
        "$settings" 2>/dev/null || echo false)"
    if [[ "$present" != "true" ]]; then
        GUARD="$guard" yq -p=json -o=json -i \
            '.hooks.PreToolUse = (.hooks.PreToolUse // []) + [{"matcher": "Bash", "hooks": [{"type": "command", "command": strenv(GUARD)}]}]' \
            "$settings"
        say "✓ merged sdev staging-guard hook into ~/.claude/settings.json"
    fi
}

# --- 1. dependency check ----------------------------------------------------
os="$(uname -s)"
ok=1
if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
    warn "✗ bash >= 4 required (found ${BASH_VERSION:-?})."
    if [[ "$os" == Darwin ]]; then warn "   macOS: brew install bash"
    else warn "   Linux: install a newer bash via your package manager"; fi
    ok=0
else say "✓ bash ${BASH_VERSINFO[0]}"; fi
_yq_major=0
if command -v yq >/dev/null 2>&1; then
    _yq_major="$(yq --version 2>/dev/null | grep -oE '[0-9]+' | head -1)"; _yq_major="${_yq_major:-0}"
fi
# yq/jq were runtime deps of the bash tool; the native Go binary needs neither.
# They only matter now for the (dormant) bash fallback, so they are advisory.
if [[ "$_yq_major" -ge 4 ]]; then
    say "✓ yq ($(yq --version 2>/dev/null))"
else
    warn "⚠️  yq v4 not found — only needed for the legacy bash fallback (the native binary needs none)."
fi
if command -v jq >/dev/null 2>&1; then say "✓ jq ($(jq --version 2>/dev/null))"; else
    warn "⚠️  jq not found — only needed for the legacy bash fallback (the native binary needs none)."
fi
# docker is a RUNTIME dep (needed for 'sdev up'), not an install-time one — warn,
# don't block. This keeps the installer usable on machines that add Docker later
# (and lets CI run the suite on runners without Docker, e.g. GitHub macOS).
if command -v docker >/dev/null 2>&1; then say "✓ docker"; else
    warn "⚠️  docker not found — install Docker Desktop or OrbStack before 'sdev up' (not required to install)."
fi
if command -v git >/dev/null 2>&1; then say "✓ git"; else
    warn "✗ git not found (required for project setup and tasks)."
    if [[ "$os" == Darwin ]]; then warn "   macOS: xcode-select --install (or brew install git)"
    else warn "   Linux: install git via your package manager"; fi
    ok=0
fi
if [[ $ok -ne 1 ]]; then
    warn ""; warn "Install the missing dependencies above, then re-run ./install."
    exit 1
fi

# Safety: never treat $HOME or / as the install dir (the copy loop rm -rf's items under it).
case "$INSTALL_DIR" in
    "$HOME"|"$HOME/"|"/"|"") warn "✗ refusing unsafe SDEV_INSTALL='$INSTALL_DIR'"; exit 1 ;;
esac

# --- 2. place the tool ------------------------------------------------------
if [[ "$SRC_DIR" == "$INSTALL_DIR" ]]; then
    say "✓ tool already at $INSTALL_DIR (running from install dir; skipping copy)"
else
    mkdir -p "$INSTALL_DIR"
    for item in bin core README.md LICENSE VERSION confs install install.sh self-update claude; do
        [[ -e "$SRC_DIR/$item" ]] || continue
        rm -rf "${INSTALL_DIR:?}/$item"
        cp -R "$SRC_DIR/$item" "$INSTALL_DIR/$item"
    done
    chmod +x "$INSTALL_DIR/bin/"* 2>/dev/null || true
    chmod +x "$INSTALL_DIR/claude/hooks/"* 2>/dev/null || true
    chmod +x "$INSTALL_DIR/install" "$INSTALL_DIR/install.sh" "$INSTALL_DIR/self-update" 2>/dev/null || true
    say "✓ tool installed to $INSTALL_DIR"
fi

# --- 2b. select the native Go binary as the sdev entrypoint -----------------
# dist ships per-platform binaries as bin/sdev-<os>-<arch>. Replace the bash
# router with the host's native binary when one is present, so `sdev` runs with
# no bash/yq/jq at runtime. Falls back to the bash runtime when none matches.
host_os="$(uname -s | tr '[:upper:]' '[:lower:]')"
host_arch="$(uname -m)"
case "$host_arch" in
    x86_64|amd64) host_arch=amd64 ;;
    arm64|aarch64) host_arch=arm64 ;;
esac
host_bin="$INSTALL_DIR/bin/sdev-$host_os-$host_arch"
if [[ -x "$host_bin" ]]; then
    cp "$host_bin" "$INSTALL_DIR/bin/sdev"
    chmod +x "$INSTALL_DIR/bin/sdev"
    rm -f "$INSTALL_DIR/bin/sdev-"*-* 2>/dev/null || true   # drop the other platforms
    say "✓ sdev is the native Go binary ($host_os/$host_arch) — no bash/yq/jq at runtime"
else
    say "✓ sdev runs via the bash runtime (no matching native binary shipped)"
fi

# --- 3. resolve the project home --------------------------------------------
# Interactive: always ask, pre-filling the best-known value as the default.
# Non-interactive: honour $SDEV_HOME / $WORKSPACE_ROOT, else read one piped line, else ~/.sdev.
FROM_PROMPT=0
if [[ -t 0 ]]; then
    FROM_PROMPT=1
    default_home="${SDEV_HOME:-${WORKSPACE_ROOT:-$HOME/.sdev}}"
    attempts=0
    while :; do
        printf 'Where should sdev keep your projects, configs & repos? [%s]: ' "$default_home" >&2
        IFS= read -r reply || reply=""
        reply="$(expand_path "${reply:-$default_home}")"
        if validate_home "$reply"; then HOME_DIR="$reply"; break; fi
        attempts=$((attempts + 1))
        [[ $attempts -ge 5 ]] && { warn "✗ no valid project home after 5 tries — aborting."; exit 1; }
    done
elif [[ -n "${SDEV_HOME:-}" ]]; then
    HOME_DIR="$SDEV_HOME"
elif [[ -n "${WORKSPACE_ROOT:-}" ]]; then
    HOME_DIR="$WORKSPACE_ROOT"
else
    FROM_PROMPT=1
    IFS= read -r reply || reply=""
    reply="$(expand_path "${reply:-$HOME/.sdev}")"
    validate_home "$reply" || { warn "✗ invalid project home '$reply' — aborting."; exit 1; }
    HOME_DIR="$reply"
fi
export SDEV_HOME="$HOME_DIR"
say "✓ project home: $HOME_DIR"

# --- 4. create user-data home (idempotent; never clobbers) ------------------
mkdir -p "$HOME_DIR/core/projects.d" "$HOME_DIR/confs" "$HOME_DIR/projects/_archive"
if [[ ! -f "$HOME_DIR/core/.task-config.yml" && -f "$INSTALL_DIR/core/.task-config.yml" ]]; then
    cp "$INSTALL_DIR/core/.task-config.yml" "$HOME_DIR/core/.task-config.yml"
    say "✓ seeded $HOME_DIR/core/.task-config.yml"
fi
say "✓ user-data home ready at $HOME_DIR"

# --- 5. wire PATH + persist exports -----------------------------------------
mkdir -p "$BIN_DIR"
ln -sf "$INSTALL_DIR/bin/sdev" "$BIN_DIR/sdev"
say "✓ linked $BIN_DIR/sdev -> $INSTALL_DIR/bin/sdev"
# Standalone self-update entrypoint (works even without the `sdev update` dispatch).
if [[ -f "$INSTALL_DIR/self-update" ]]; then
    ln -sf "$INSTALL_DIR/self-update" "$BIN_DIR/sdev-update"
    say "✓ linked $BIN_DIR/sdev-update -> $INSTALL_DIR/self-update"
fi
if [[ $FROM_PROMPT -eq 1 ]]; then
    # We chose the project home for the user, so own the rc wiring too (SDEV_HOME + PATH).
    persist_rc "$(detect_rc)"
else
    # Home came from the environment; the user manages their own env. Just advise on PATH.
    case ":$PATH:" in
        *":$BIN_DIR:"*) : ;;
        *)
            say ""
            say "Add $BIN_DIR to your PATH (e.g. in ~/.zshrc or ~/.bashrc):"
            say "    export PATH=\"$BIN_DIR:\$PATH\""
            ;;
    esac
fi

# --- 6. optional: Claude Code skill + command ------------------------------
maybe_install_claude

cat <<EOF

Done. Next:
  sdev init      # configure your first project
EOF
