# Users' live task workspaces and secrets are never committed.
/projects/
# Central allocation ledger + warm worktree pool (runtime state under $SDEV_HOME).
/state/
# GSD/agent session artifacts (not part of the package).
/.planning/
# Brainstorm/plan docs from the superpowers workflow (kept locally, not tracked).
/docs/superpowers/
**/*.env
!**/*.env.example
.DS_Store
*.bak

# dist build output
/build/

# compiled Go binary (built by CI / dev; strangler router falls back to bash)
/bin/sdev-go
